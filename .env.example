# ─────────────────────────────────────────────────────────────────────────────
# Volt-Connect Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase PostgreSQL ───────────────────────────────────────────────────────
# Full JDBC URL, e.g.: jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=jdbc:postgresql://<host>:5432/postgres
SUPABASE_DB_USERNAME=postgres
SUPABASE_DB_PASSWORD=<your-supabase-db-password>

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Firebase project ID (found in Firebase console → Project settings)
FIREBASE_PROJECT_ID=<your-firebase-project-id>
# Absolute or relative path to the service-account JSON file
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-service-account.json

# ── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_<your-key-id>
RAZORPAY_SECRET=<your-razorpay-secret>
RAZORPAY_WEBHOOK_SECRET=<your-razorpay-webhook-secret>

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a long, random, base64-encoded secret (minimum 256 bits / 32 bytes)
JWT_SECRET=<your-jwt-secret-min-32-chars>
# Access token expiry in milliseconds (default: 3600000 = 1 hour)
JWT_EXPIRY=3600000
# Refresh token expiry in milliseconds (default: 2592000000 = 30 days)
JWT_REFRESH_EXPIRY=2592000000

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Spring Profile ────────────────────────────────────────────────────────────
# Set to 'dev' for local development, 'prod' for production
SPRING_PROFILES_ACTIVE=dev

# ── Mail (optional) ───────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=<your-email@gmail.com>
MAIL_PASSWORD=<your-app-password>
